<routes>

<!-- NORTH -->
<route id="n_s" edges="n_in s_out"/>
<route id="n_e" edges="n_in e_out"/>
<route id="n_w" edges="n_in w_out"/>

<!-- SOUTH -->
<route id="s_n" edges="s_in n_out"/>
<route id="s_e" edges="s_in e_out"/>
<route id="s_w" edges="s_in w_out"/>

<!-- EAST -->
<route id="e_w" edges="e_in w_out"/>
<route id="e_n" edges="e_in n_out"/>
<route id="e_s" edges="e_in s_out"/>

<!-- WEST -->
<route id="w_e" edges="w_in e_out"/>
<route id="w_n" edges="w_in n_out"/>
<route id="w_s" edges="w_in s_out"/>

<!-- MIXED FLOWS WITH TURNS (NO U-TURNS) -->

<!-- ================= NORTH ================= -->

<!-- Straight -->
<flow id="ns_bike" type="bike" route="n_s" begin="0" end="30000000" probability="0.15"/>
<flow id="ns_auto" type="auto" route="n_s" begin="0" end="30000000" probability="0.10"/>
<flow id="ns_car"  type="car"  route="n_s" begin="0" end="30000000" probability="0.10"/>
<flow id="ns_bus"  type="bus"  route="n_s" begin="0" end="30000000" probability="0.025"/>
<flow id="ns_truck" type="truck" route="n_s" begin="0" end="30000000" probability="0.025"/>

<!-- Left -->
<flow id="ne_bike" type="bike" route="n_e" begin="0" end="30000000" probability="0.075"/>
<flow id="ne_auto" type="auto" route="n_e" begin="0" end="30000000" probability="0.05"/>
<flow id="ne_car"  type="car"  route="n_e" begin="0" end="30000000" probability="0.05"/>

<!-- Right -->
<flow id="nw_bike" type="bike" route="n_w" begin="0" end="30000000" probability="0.075"/>
<flow id="nw_auto" type="auto" route="n_w" begin="0" end="30000000" probability="0.05"/>
<flow id="nw_car"  type="car"  route="n_w" begin="0" end="30000000" probability="0.05"/>


<!-- ================= SOUTH ================= -->

<!-- Straight -->
<flow id="sn_bike" type="bike" route="s_n" begin="0" end="30000000" probability="0.15"/>
<flow id="sn_auto" type="auto" route="s_n" begin="0" end="30000000" probability="0.10"/>
<flow id="sn_car"  type="car"  route="s_n" begin="0" end="30000000" probability="0.10"/>
<flow id="sn_bus"  type="bus"  route="s_n" begin="0" end="30000000" probability="0.025"/>
<flow id="sn_truck" type="truck" route="s_n" begin="0" end="30000000" probability="0.025"/>

<!-- Left -->
<flow id="se_bike" type="bike" route="s_e" begin="0" end="30000000" probability="0.075"/>
<flow id="se_auto" type="auto" route="s_e" begin="0" end="30000000" probability="0.05"/>
<flow id="se_car"  type="car"  route="s_e" begin="0" end="30000000" probability="0.05"/>

<!-- Right -->
<flow id="sw_bike" type="bike" route="s_w" begin="0" end="30000000" probability="0.075"/>
<flow id="sw_auto" type="auto" route="s_w" begin="0" end="30000000" probability="0.05"/>
<flow id="sw_car"  type="car"  route="s_w" begin="0" end="30000000" probability="0.05"/>


<!-- ================= EAST ================= -->

<!-- Straight -->
<flow id="ew_bike" type="bike" route="e_w" begin="0" end="30000000" probability="0.15"/>
<flow id="ew_auto" type="auto" route="e_w" begin="0" end="30000000" probability="0.10"/>
<flow id="ew_car"  type="car"  route="e_w" begin="0" end="30000000" probability="0.10"/>
<flow id="ew_bus"  type="bus"  route="e_w" begin="0" end="30000000" probability="0.025"/>
<flow id="ew_truck" type="truck" route="e_w" begin="0" end="30000000" probability="0.025"/>

<!-- Left -->
<flow id="en_bike" type="bike" route="e_n" begin="0" end="30000000" probability="0.075"/>
<flow id="en_auto" type="auto" route="e_n" begin="0" end="30000000" probability="0.05"/>
<flow id="en_car"  type="car"  route="e_n" begin="0" end="30000000" probability="0.05"/>

<!-- Right -->
<flow id="es_bike" type="bike" route="e_s" begin="0" end="30000000" probability="0.075"/>
<flow id="es_auto" type="auto" route="e_s" begin="0" end="30000000" probability="0.05"/>
<flow id="es_car"  type="car"  route="e_s" begin="0" end="30000000" probability="0.05"/>


<!-- ================= WEST ================= -->

<!-- Straight -->
<flow id="we_bike" type="bike" route="w_e" begin="0" end="30000000" probability="0.15"/>
<flow id="we_auto" type="auto" route="w_e" begin="0" end="30000000" probability="0.10"/>
<flow id="we_car"  type="car"  route="w_e" begin="0" end="30000000" probability="0.10"/>
<flow id="we_bus"  type="bus"  route="w_e" begin="0" end="30000000" probability="0.025"/>
<flow id="we_truck" type="truck" route="w_e" begin="0" end="30000000" probability="0.025"/>

<!-- Left -->
<flow id="wn_bike" type="bike" route="w_n" begin="0" end="30000000" probability="0.075"/>
<flow id="wn_auto" type="auto" route="w_n" begin="0" end="30000000" probability="0.05"/>
<flow id="wn_car"  type="car"  route="w_n" begin="0" end="30000000" probability="0.05"/>

<!-- Right -->
<flow id="ws_bike" type="bike" route="w_s" begin="0" end="30000000" probability="0.075"/>
<flow id="ws_auto" type="auto" route="w_s" begin="0" end="30000000" probability="0.05"/>
